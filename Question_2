def parse_term(tokens, pos):
    left = parse_primary(tokens, pos) # take the left value
    
    while current(tokens, pos) in ('*', '/'): # is the next token on the conveyor a '*' or '/'
        op = consume(tokens, pos) # select the '*' or '/'
        right = parse_primary(tokens, pos) # get the right side
        left = ('binop', op, left, right) # combine into tree node
        
    return left
    
    def parse_expression(tokens, pos): # now to deal with the '+' and '-'
        left = parse_term(tokens, pos)
        while current(tokens, pos) in ('+', '-'): 
        op = consume(tokens, pos)           # select the + or -
        right = parse_term(tokens, pos)     # get the right side
        left = ('binop', op, left, right)   # combine into a tree node

    return left

# We now have the Tree parameters

def tree_to _string(node):
    kind = node[0]   # Defining the node type 
    
    if kind == 'num':
        return str(node[1]) # it is a simple number
    
    if kind == 'neg':
        inner = tree_to_string(node[1])
        return f"(neg {inner})" # convert with number to say (neg 7)
    
    if kind == 'binop':
        op = node[1]
        left  = tree_to_string(node[2])   # convert left side
        right = tree_to_string(node[3])   # convert right side
        return f"({op} {left} {right})"   # combine e.g. "(+ 2.0 3.0)"
    

# We have assembled the tree now the calculation

def evaluate_tree(node):
    kind = node[0]

    if kind == 'num':
        return node[1]   # just give me the number

    if kind == 'neg':
        return -evaluate_tree(node[1])   # negative number inside
    

    if kind == 'binop': # using the operators left and right
        op    = node[1]
        left  = evaluate_tree(node[2])   # calculate left side first
        right = evaluate_tree(node[3])   # calculate right side
        if op == '+': return left + right
        if op == '-': return left - right
        if op == '*': return left * right
        if op == '/': return left / right
